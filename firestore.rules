rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    function isValidUser(data) {
      return (data.dailyGoal == null || data.dailyGoal is number)
             && (data.email == null || data.email is string)
             && (data.waterGoal == null || data.waterGoal is number)
             && (data.waterIntake == null || data.waterIntake is number)
             && (data.notifiedToday == null || data.notifiedToday is bool)
             && (data.waterRemindersEnabled == null || data.waterRemindersEnabled is bool)
             && (data.reminderInterval == null || data.reminderInterval is number)
             && (data.lastResetDate == null || data.lastResetDate is string)
             && (data.theme == null || data.theme in ['dark', 'light'])
             && (data.mealRemindersEnabled == null || data.mealRemindersEnabled is bool)
             && (data.breakfastReminder == null || data.breakfastReminder is string)
             && (data.lunchReminder == null || data.lunchReminder is string)
             && (data.dinnerReminder == null || data.dinnerReminder is string)
             && (data.firstUsedTimestamp == null || data.firstUsedTimestamp is number)
             && (data.hasRated == null || data.hasRated is bool)
             && (data.targetWeight == null || data.targetWeight is number);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isSignedIn(); 
      allow update: if isOwner(userId) && isSignedIn();
    }

    // --- Meal Rules ---
    function isValidMeal(data) {
      return data.userId == request.auth.uid
             && data.foodName is string && data.foodName.size() <= 256
             && data.calories is number && data.calories >= 0
             && data.timestamp is number
             && data.date is string;
    }

    match /meals/{mealId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn(); // Allow reading any meal if shared (ID known)
      allow create: if isVerified() && isValidMeal(incoming());
      allow update: if isVerified() && isOwner(incoming().userId) && isValidMeal(incoming()); 
      allow delete: if isVerified() && resource.data.userId == request.auth.uid;
    }

    // --- Weight History Rules ---
    function isValidWeight(data) {
      return data.userId == request.auth.uid
             && data.weight is number && data.weight > 0
             && data.timestamp is number;
    }

    match /weightHistory/{weightId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidWeight(incoming());
      allow update: if false;
      allow delete: if isVerified() && resource.data.userId == request.auth.uid;
    }

    // --- Feedback Rules ---
    function isValidFeedback(data) {
      return data.userId == request.auth.uid
             && data.mealId is string && data.mealId.size() <= 256
             && data.foodName is string && data.foodName.size() <= 200
             && data.originalCalories is number
             && data.correctedCalories is number
             && data.isAccurate is bool
             && data.timestamp is number
             && (data.imageUrl == null || data.imageUrl is string);
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow read: if false; 
    }

    // --- App Configuration Rules ---
    match /appConfig/branding {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'sahilmakandar460@gmail.com' && request.auth.token.email_verified == true;
    }

    // Support for testConnection
    match /test/connection {
      allow get: if true;
    }
  }
}
